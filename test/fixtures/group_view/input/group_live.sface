<main
  data-id={if @type == :topic, do: "topic", else: "group"}
  data-group-id={e(@category, :id, "")}
>
  {#if e(@category, :deleted_at, nil) && @type != :topic}
    {!-- Archived group: restore notice up top, hero below as an inert preview --}
    <div
      class="mb-4 flex flex-col gap-3 rounded-xl border border-secondary bg-base-200 p-4 sm:flex-row sm:items-center"
      role="status"
    >
      <div class="flex flex-1 items-start gap-3">
        <div class="grid size-10 shrink-0 place-items-center rounded-lg bg-base-content/5">
          <#Icon iconify="ph:archive-duotone" class="size-5 text-muted" />
        </div>
        <div class="flex-1">
          <div class="font-medium text-base-content">{l("This group is archived")}</div>
          <p class="mt-0.5 text-sm text-muted">
            {l("It's hidden from members and listings. Restore it to bring it back online.")}
          </p>
        </div>
      </div>
      {#if Bonfire.Classify.ensure_update_allowed(current_user(@__context__), @category)}
        <button
          type="button"
          id="group_unarchive_button"
          :on-click="Bonfire.Classify:unarchive"
          data-confirm={l("Restore this group and bring it back online?")}
          class="btn btn-primary btn-sm shrink-0 gap-2 normal-case sm:self-center"
        >
          <#Icon iconify="ph:arrow-counter-clockwise" class="size-4" />
          {l("Unarchive")}
        </button>
      {/if}
    </div>
    <div
      class="pointer-events-none opacity-70 grayscale-[40%]"
      aria-label={l("Preview of the archived group")}
    >
      <StatefulComponent
        module={Config.get(
          [:ui, :group, :hero_component],
          Bonfire.UI.Me.ProfileHeroFullLive
        )}
        id={deterministic_dom_id("profile_hero", id(@category), "archived", @character_type)}
        user={@category}
        path={@path}
        character_type={:group}
        boundary_preset={@boundary_preset}
        object_boundary={@object_boundary}
        permalink={@permalink}
        follows_me={false}
        selected_tab={@selected_tab}
        members={@members}
        moderators={@moderators}
        subcategories={e(assigns, :subcategories, [])}
        preset_slug={e(assigns, :group_preset_slug, nil)}
        membership_slug={e(assigns, :group_membership_slug, nil)}
        member_count={e(assigns, :group_member_count, nil)}
        topic_count={e(assigns, :group_topic_count, nil)}
        date={e(assigns, :group_date, nil)}
      />
    </div>
  {#else}
    <StatelessComponent
      module={if @type == :topic,
        do:
          Config.get([:ui, :topic, :sections], [])[tab(@selected_tab)] ||
            Bonfire.UI.Social.ProfileTimelineLive,
        else:
          tab_component(@selected_tab) || tab_component(@tab_id) ||
            Bonfire.UI.Social.ProfileTimelineLive}
      user={@category}
      {...assigns}
    >
      <:header>
        {#if @type == :topic}
          {!-- a topic rendered in group context: show only the topic hero (which includes the
               sibling-topic nav), mirroring Bonfire.UI.Topics.CategoryLive --}
          <StatelessComponent
            module={maybe_component(Bonfire.UI.Topics.TopicHeroLive, @__context__)}
            category={@category}
            permalink={@permalink}
            object_boundary={@object_boundary}
            boundary_preset={@boundary_preset}
            subcategories={e(assigns, :subcategories, [])}
            selected_category_id={id(@category)}
            user={e(@category, :parent_category, nil)}
          />
          <StatelessComponent
            :if={@can_create_in_category}
            module={maybe_component(Bonfire.UI.Common.InlineComposerPlaceholderLive, @__context__)}
            selected_tab={@selected_tab}
            prompt={l("Write in %{name}",
              name: Bonfire.Classify.Web.Preview.CategoryLive.name(@category, l("group"))
            )}
            smart_input_opts={%{
              context_id: id(@category),
              mentions: [id(@category)],
              to_circles: Bonfire.Classify.Boundaries.post_circles_for_group(@category),
              to_boundaries: List.wrap(Bonfire.Classify.Boundaries.read_default_content_visibility(@category))
            }}
          />
        {#elseif @selected_tab == "settings"}
          <div class="sticky top-0 pt-safe z-sticky bg-base-100 lg:bg-base-100/70 backdrop-blur-sm border-b border-secondary">
            <div role="banner" class="flex items-center place-content-center flex-1 w-full min-h-[60px]">
              <div class="flex items-center gap-2 w-full">
                <LinkLive
                  to={e(@category, :permalink, nil) || @permalink}
                  id="go_back_button"
                  aria-label={l("Go back to the previous page")}
                  class="btn z-50 btn-sm btn-circle"
                >
                  <#Icon iconify="ph:arrow-left" class="w-5 h-5" />
                </LinkLive>
                <div class="flex items-center flex-1 w-full flex-1">
                  <span class="max-w-[250px] lg:max-w-[600px] font-medium text-base-content truncate text-ellipsis">
                    {e(@category, :name, l("Group"))}
                  </span>
                </div>
              </div>
            </div>
          </div>
        {#else}
          <StatefulComponent
            module={Config.get(
              [:ui, :group, :hero_component],
              Bonfire.UI.Me.ProfileHeroFullLive
            )}
            id={deterministic_dom_id("profile_hero", id(@category), @selected_tab, @character_type)}
            user={@category}
            path={@path}
            character_type={:group}
            boundary_preset={@boundary_preset}
            object_boundary={@object_boundary}
            permalink={@permalink}
            follows_me={false}
            selected_tab={@selected_tab}
            members={@members}
            moderators={@moderators}
            subcategories={e(assigns, :subcategories, [])}
            preset_slug={e(assigns, :group_preset_slug, nil)}
            membership_slug={e(assigns, :group_membership_slug, nil)}
            member_count={e(assigns, :group_member_count, nil)}
            topic_count={e(assigns, :group_topic_count, nil)}
            date={e(assigns, :group_date, nil)}
          />
          <div class="py-feed">
            <StatelessComponent
              :if={@can_create_in_category}
              module={maybe_component(Bonfire.UI.Common.InlineComposerPlaceholderLive, @__context__)}
              selected_tab={@selected_tab}
              prompt={l("Write in %{name}",
                name: Bonfire.Classify.Web.Preview.CategoryLive.name(@category, l("group"))
              )}
              smart_input_opts={%{
                context_id: id(@category),
                mentions: [id(@category)],
                to_circles: Bonfire.Classify.Boundaries.post_circles_for_group(@category),
                to_boundaries: List.wrap(Bonfire.Classify.Boundaries.read_default_content_visibility(@category))
              }}
            />
          </div>
        {/if}
      </:header>
    </StatelessComponent>
  {/if}
</main>
